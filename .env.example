# ===========================================
# trading_system_pro - Variáveis de Ambiente
# Copie para .env e preencha os valores.
# ===========================================

# --- API Keys (obrigatórias para execução) ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# --- Binance ---
BINANCE_TESTNET=false

# --- Modo e símbolo ---
TRADING_MODE=paper
TRADING_SYMBOL=BTCUSDT
LOG_LEVEL=INFO

# --- DeepSeek (opcional) ---
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Sentiment (LLM / notícias / Twitter) ---
OPENAI_API_KEY=
CRYPTOCOMPARE_API_KEY=
# Grok/xAI para sentimento Twitter/X em tempo real (opcional)
XAI_API_KEY=

# --- Sinais ---
ACCEPT_AGNO_SIGNALS=true
ACCEPT_DEEPSEEK_SIGNALS=false

# --- Risk (opcional; valores padrão do config) ---
# MAX_RISK_PER_TRADE=0.02
# MAX_DRAWDOWN=0.15
# MAX_EXPOSURE=0.50
# MAX_DAILY_TRADES=3
# INITIAL_CAPITAL=10000.0
# RISK_PERCENT_PER_TRADE=2.0
# Confiança mínima 1-10 para executar (default 6 para testar fluxo; 7-8 mais restritivo)
# MIN_CONFIDENCE_0_10=6
# MIN_ANALYSIS_INTERVAL_HOURS=2.0

# --- Reavaliação de sinais ---
# REEVALUATION_ENABLED=true
# REEVALUATION_INTERVAL_HOURS=2.0
# REEVALUATION_MIN_TIME_OPEN_HOURS=1.0
# REEVALUATION_MIN_CONFIDENCE=7

# --- Top Movers Dinâmicos (pares com maior movimento 24h) ---
# TOP_MOVERS_ENABLED=true
# TOP_MOVERS_N_GAINERS=5
# TOP_MOVERS_N_LOSERS=5
# TOP_MOVERS_MIN_VOLUME_USDT=50000000

# --- Optimizer contínuo (backtest aleatório para achar melhor setup) ---
# Mais iterações = mais combinações de RSI/EMA/MACD/BB/ADX/SL/TP testadas = mais chance de win rate alto
# PC potente (ex.: 7900x): suba OPTIMIZER_ITERATIONS para 500–1000
# OPTIMIZER_ITERATIONS=300
# OPTIMIZER_DAYS_BACK=60
# OPTIMIZER_CYCLE_HOURS=6
# OPTIMIZER_MIN_SCORE=0.35

# --- Notificações por Email (Yahoo Mail) ---
# Para usar com Yahoo Mail:
# 1. Acesse https://login.yahoo.com/account/security
# 2. Ative "Senha de app" (App Password)
# 3. Gere uma senha de app para "Outro app"
# 4. Use essa senha no EMAIL_SMTP_PASSWORD
EMAIL_SMTP_USER=seu_email@yahoo.com
EMAIL_SMTP_PASSWORD=sua_senha_de_app_aqui
EMAIL_SMTP_HOST=smtp.mail.yahoo.com
EMAIL_SMTP_PORT=587
EMAIL_TO=seu_email@yahoo.com
# EMAIL_NOTIFICATIONS_ENABLED=true

# --- Notificações - Outros canais (opcional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=

# --- ML ---
# ML_VALIDATION_ENABLED=true
# ML_VALIDATION_THRESHOLD=0.65
# ML_VALIDATION_REQUIRED=false
# ML_ONLINE_LEARNING_ENABLED=true
# ML_RETRAIN_THRESHOLD=50
# ML_MIN_IMPROVEMENT=0.0
# ML_AUTO_TRAIN_HOURS=12  # Treino automático a cada N horas (0=desativado)
