# ==========================================
# Trading System Pro - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values

# API Keys (REQUIRED)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Binance API (required for real trading mode)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Trading Mode: "paper" (simulation) or "real" (live trading)
TRADING_MODE=paper

# Signal Sources
ACCEPT_AGNO_SIGNALS=true
ACCEPT_DEEPSEEK_SIGNALS=false

# Risk Management
MIN_CONFIDENCE_0_10=7
MAX_RISK_PER_TRADE=0.02
MAX_DRAWDOWN=0.15
MAX_DAILY_TRADES=3
INITIAL_CAPITAL=10000.0

# Analysis
MIN_ANALYSIS_INTERVAL_HOURS=2.0
TRADING_SYMBOL=BTCUSDT

# ML Validation
ML_VALIDATION_ENABLED=true
ML_VALIDATION_THRESHOLD=0.65
ML_VALIDATION_REQUIRED=false

# Logging
LOG_LEVEL=INFO
